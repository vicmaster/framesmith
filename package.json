{
  "name": "framesmith",
  "version": "1.5.1",
  "description": "MCP server that gives any AI assistant a visual design canvas",
  "type": "module",
  "bin": {
    "framesmith": "./dist/index.js",
    "framesmith-viewer": "./dist/viewer-standalone.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "docs/GUIDELINES.md"
  ],
  "scripts": {
