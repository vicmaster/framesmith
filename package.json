    "viewer": "tsx src/viewer-standalone.ts",
    "bench": "tsx benchmark/run.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "@material-symbols/svg-400": "^0.44.12",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "lucide-static": "^0.577.0",
    "nanoid": "^5.1.5",
    "openai": "^6.38.0",
    "puppeteer": "^24.7.2",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "license": "MIT"
}
